# Required: 32+ random bytes used to sign session cookies and exam tokens.
# Generate via: openssl rand -hex 32
SESSION_SECRET=change-me-to-32-random-bytes

# Required: the access code your trusted users will type to enter the site.
USER_ACCESS_CODE=MEDIK2026

# Required: the access code that opens /admin (lock/unlock the site, see device count).
ADMIN_ACCESS_CODE=ADMIN2026

# Optional: link shown on the "Підтримати автора" page.
MONOBANK_JAR_URL=https://send.monobank.ua/jar/5EMm6vHGxk

# --- Production-only (auto-injected by Vercel KV / Upstash integration) ---
# Do NOT set these manually. When you connect a Vercel KV / Upstash for Redis
# instance to this project on Vercel, these are populated automatically.
# Without them, the app falls back to an in-memory store (fine for local dev,
# NOT for production — state resets on every cold start).
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
